# ── General ──
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-prod
LOG_LEVEL=debug

# ── Database ──
DATABASE_URL=postgres+asyncpg://qara:qara_dev@localhost:5432/qara_dev

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Storage (MinIO / S3) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=qara_access
S3_SECRET_KEY=qara_secret
S3_BUCKET=qara-captures

# ── LLM (9Router) ──
NINE_ROUTER_URL=http://localhost:20128/v1
NINE_ROUTER_API_KEY=
NINE_ROUTER_MODEL_DEFAULT=qoder/qmodel-latest
NINE_ROUTER_MODEL_TRIAGE=qoder/qmodel-latest
NINE_ROUTER_MODEL_GENERATE=antigravity/claude-sonnet
NINE_ROUTER_MODEL_RAG=qoder/qmodel-latest

# ── Auth ──
JWT_SECRET=dev-jwt-secret-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
REFRESH_TOKEN_EXPIRY_DAYS=7

# ── Integrations ──
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#qa-alerts
JIRA_URL=
JIRA_USER=
JIRA_API_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ── Capture ──
CAPTURE_UPLOAD_MAX_SIZE_MB=50
CAPTURE_SESSION_MAX_DURATION_MINUTES=30
CAPTURE_STORAGE_BACKEND=local

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
