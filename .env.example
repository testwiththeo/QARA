# === Database ===
# Docker: postgresql+asyncpg://qara:qara@postgres:5432/qara
# Local:  postgresql+asyncpg://qara:qara@localhost:5432/qara
DATABASE_URL=postgresql+asyncpg://qara:qara@postgres:5432/qara
DATABASE_URL_SYNC=postgresql://qara:qara@postgres:5432/qara

# === Redis ===
# Docker: redis://redis:6379/0
# Local:  redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# === MinIO (S3) ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=qara-captures
MINIO_USE_SSL=false

# === 9Router (LLM) ===
NINE_ROUTER_URL=http://host.docker.internal:20128/v1
NINE_ROUTER_MODEL=qoder/qmodel-latest
EMBEDDING_PROVIDER=9router
EMBEDDING_DIMENSION=384

# === Auth / JWT ===
JWT_SECRET=change-me-to-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Server ===
API_HOST=0.0.0.0
API_PORT=8000
API_MAX_UPLOAD_SIZE=52428800

# === Worker ===
ARQ_MAX_TRIES=3
ARQ_RETRY_DELAY=10
